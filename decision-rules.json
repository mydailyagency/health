{
  "schema_version": "1.0",
  "locale": "en-US",
  "questionnaire": [
    {
      "id": "Q1",
      "text": "What is your date of birth (or age)?",
      "input_type": "date_or_number",
      "required": true,
      "maps_to": "demographics.age",
      "feeds_rules": ["DM-001","DM-009"]
    },
    {
      "id": "Q2",
      "text": "What is your sex at birth?",
      "input_type": "single_choice",
      "options": ["male","female","prefer_not_say"],
      "required": true,
      "maps_to": "demographics.sex",
      "feeds_rules": ["MOD-005","MOD-006","MOV-006"]
    },
    {
      "id": "Q3",
      "text": "Which best describes your current hormonal stage (if applicable)?",
      "input_type": "single_choice",
      "show_if": "Q2 in ['male','female']",
      "options": [
        "none","menstruating","perimenopause","menopause",
        "pregnant","postpartum","andropause","TRT"
      ],
      "maps_to": "demographics.hormonal_stage",
      "feeds_rules": ["MOD-005","MOD-006","MOV-006"]
    },
    {
      "id": "Q4",
      "text": "What is your height?",
      "input_type": "number_cm",
      "required": true,
      "maps_to": "body.height_cm",
      "feeds_rules": ["DM-001","DM-002"]
    },
    {
      "id": "Q5",
      "text": "What is your weight?",
      "input_type": "number_kg",
      "required": true,
      "maps_to": "body.weight_kg",
      "feeds_rules": ["DM-001"]
    },
    {
      "id": "Q6",
      "text": "What is your waist measurement (around your belly button)?",
      "input_type": "number_cm",
      "required": false,
      "maps_to": "body.waist_cm",
      "feeds_rules": ["DM-002"]
    },
    {
      "id": "Q7",
      "text": "What are your top 2–3 health or wellness goals?",
      "input_type": "multi_choice",
      "options": [
        "fat_loss","muscle_gain","strength","endurance","energy",
        "sleep","stress","longevity","mobility","pain_reduction","metabolic_health"
      ],
      "max_choices": 3,
      "maps_to": "goals",
      "feeds_rules": ["DM-006","DM-009","L1-001"]
    },
    {
      "id": "Q8",
      "text": "Which goal do you want to focus on first?",
      "input_type": "single_choice",
      "show_if": "Q7 has value",
      "options_dynamic_from": "Q7",
      "maps_to": "goals.primary_focus",
      "feeds_rules": ["DM-009"]
    },
    {
      "id": "Q9",
      "text": "On average, how many steps do you take per day?",
      "input_type": "single_choice",
      "options": ["<3000","3000-5000","5000-7500","7500-10000",">10000"],
      "maps_to": "activity.baseline_steps",
      "feeds_rules": ["DM-003","MOV-002"]
    },
    {
      "id": "Q10",
      "text": "How much cardio exercise do you get in a typical week?",
      "input_type": "single_choice",
      "options": ["none","<60 min","60-150 min","150-300 min",">300 min"],
      "maps_to": "activity.cv_minutes_week",
      "feeds_rules": ["DM-003","MOV-001"]
    },
    {
      "id": "Q11",
      "text": "How often do you perform strength training?",
      "input_type": "single_choice",
      "options": ["never","1","2","3+"],
      "maps_to": "activity.resistance_days_week",
      "feeds_rules": ["MOV-003","MOV-006"]
    },
    {
      "id": "Q13",
      "text": "On average, how many hours of sleep do you get per night?",
      "input_type": "number_hours",
      "maps_to": "sleep.avg_hours",
      "feeds_rules": ["DM-005","SLP-001","SLP-002"]
    },
    {
      "id": "Q14",
      "text": "Do you work night shifts or rotating shifts?",
      "input_type": "yes_no",
      "maps_to": "sleep.shift_work",
      "feeds_rules": ["SLP-003"]
    },
    {
      "id": "Q15",
      "text": "Do you have trouble falling or staying asleep 3+ nights/week?",
      "input_type": "yes_no",
      "maps_to": "sleep.insomnia_flag",
      "feeds_rules": ["SLP-004"]
    },
    {
      "id": "Q16",
      "text": "Has anyone told you that you snore or stop breathing during sleep?",
      "input_type": "yes_no",
      "maps_to": "sleep.osa_risk",
      "feeds_rules": ["DM-007","MOD-012","SLP-005"]
    },
    {
      "id": "Q18",
      "text": "Which best describes your eating pattern?",
      "input_type": "single_choice",
      "options": [
        "omnivore","mediterranean","vegetarian","vegan",
        "gluten_free","lactose_free","keto","other"
      ],
      "maps_to": "diet.pattern",
      "feeds_rules": ["NUT-004","NUT-009","MOD-011"]
    },
    {
      "id": "Q23",
      "text": "Do you have or have you ever been told you have any of the following conditions?",
      "input_type": "multi_choice",
      "options": [
        "prediabetes","t2d","htn","dyslipidemia","obesity",
        "pcos","ckd","asthma","copd","cad","stroke","nafld",
        "gerd","ibs","celiac","hypothyroid","hyperthyroid",
        "depression","anxiety","adhd","chronic_pain","osteoarthritis",
        "osteopenia","osteoporosis","osa","none"
      ],
      "maps_to": "health.diagnoses",
      "feeds_rules": ["MOD-001","MOD-002","MOD-003","MOD-004","MOD-007","MOD-008","MOD-009","MOD-010"]
    },
    {
      "id": "Q24",
      "text": "Do you know your average blood pressure?",
      "input_type": "number_pair",
      "show_if": "Q23 includes 'htn'",
      "maps_to": ["vitals.home_bp_sbp","vitals.home_bp_dbp"],
      "feeds_rules": ["DM-004","MOD-001"]
    },
    {
      "id": "Q27",
      "text": "In the past 2 weeks, how often have you felt little interest or pleasure in doing things?",
      "input_type": "phq2_scale",
      "maps_to": "screening.phq2",
      "feeds_rules": ["DM-007","MEN-002"]
    },
    {
      "id": "Q29",
      "text": "In the past 2 weeks, how often have you felt nervous, anxious, or on edge?",
      "input_type": "gad2_scale",
      "maps_to": "screening.gad2",
      "feeds_rules": ["DM-007","MEN-002"]
    },
    {
      "id": "Q31",
      "text": "What do you see as your biggest barriers to improving your health?",
      "input_type": "multi_choice",
      "options": ["time","stress","pain","motivation","budget","food_access","equipment","knowledge","other"],
      "max_choices": 3,
      "maps_to": "readiness.barriers",
      "feeds_rules": ["ENV-003","L2-002"]
    },
    {
      "id": "Q32",
      "text": "On a scale from 0–10, how confident are you in your ability to make changes now?",
      "input_type": "number_0_10",
      "maps_to": "readiness.confidence_0_10",
      "feeds_rules": ["L2-002"]
    }
  ],
  "rules": [
    {
      "id": "DM-001",
      "name": "Calculate BMI",
      "priority": 100,
      "applies_to_levels": ["L1","L2","L3"],
      "when": "body.bmi == null && body.weight_kg != null && body.height_cm != null",
      "then": [{"set":"body.bmi","to":"body.weight_kg / ((body.height_cm/100)**2)"}]
    },
    {
      "id": "DM-002",
      "name": "Calculate waist-to-height ratio",
      "priority": 100,
      "applies_to_levels": ["L1","L2","L3"],
      "when": "body.waist_cm != null && body.height_cm != null",
      "then": [{"set":"body.whtr","to":"body.waist_cm / body.height_cm"}]
    },
    {
      "id": "DM-003",
      "name": "Activity band",
      "priority": 90,
      "applies_to_levels": ["L1","L2","L3"],
      "when": "true",
      "then": [{"set":"activity.activity_band","to":"computeActivityBand(activity)"}]
    },
    {
      "id": "DM-004",
      "name": "Blood pressure band",
      "priority": 90,
      "applies_to_levels": ["L1","L2","L3"],
      "when": "vitals.home_bp_sbp != null && vitals.home_bp_dbp != null",
      "then": [{"set":"vitals.bp_band","to":"computeBPBand(vitals.home_bp_sbp,vitals.home_bp_dbp)"}]
    },
    {
      "id": "DM-005",
      "name": "Sleep adequacy",
      "priority": 90,
      "applies_to_levels": ["L1","L2","L3"],
      "when": "sleep.avg_hours != null",
      "then": [
        {"set":"sleep.sleep_band","to":"computeSleepBand(sleep.avg_hours)"},
        {"set":"sleep.sleep_irregular","to":"sleep.variability_hours != null && sleep.variability_hours > 1.0"}
      ]
    },
    {
      "id": "DM-007",
      "name": "Risk flags",
      "priority": 85,
      "applies_to_levels": ["L1","L2","L3"],
      "when": "true",
      "then": [
        {"set":"risk_flags.risk_osa","to":"sleep.osa_risk=='yes'"},
        {"set":"risk_flags.risk_htn","to":"health.diagnoses.includes('htn') || vitals.bp_band == 'htn_range'"}
      ]
    },
    {
      "id": "MOD-001",
      "name": "HTN/DASH module",
      "priority": 95,
      "applies_to_levels": ["L1","L2","L3"],
      "when": "risk_flags.risk_htn",
      "then": [
        {"include_module":"dash_module"},
        {"set":"nutrition.sodium_target","to":2300},
        {"add_to_top_actions":"Sodium audit and DASH diet swaps"}
      ]
    },
    {
      "id": "MOV-002",
      "name": "Steps progression",
      "priority": 80,
      "applies_to_levels": ["L1","L2","L3"],
      "when": "activity.baseline_steps != null",
      "then": [
        {"set":"plan.steps.week1_target","to":"Math.ceil(activity.baseline_steps * 1.10)"},
        {"set":"plan.steps.progression_rule","to":"+10% per week until 7000-10000 steps/day"}
      ]
    },
    {
      "id": "L1-001",
      "name": "Top 5 actions constructor",
      "priority": 50,
      "applies_to_levels": ["L1"],
      "when": "true",
      "then": [{"call":"composeTop5Actions(context)"}]
    }
  ]
}
